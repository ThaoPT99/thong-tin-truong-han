{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "lib/**/*",
    "api/**/*",
    "scripts/**/*",
    "public/js/*.js",
    "vitest.config.ts",
    "*.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "public/truong/**/*",
    "*.test.ts",
    "*.spec.ts"
  ]
}