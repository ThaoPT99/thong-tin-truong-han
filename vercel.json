{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/truong/([^/]+)$", "destination": "/truong/$1/index.html" },
    { "source": "/(admin/[^/]+\\.html)$", "destination": "/$1" },
    { "source": "/admin/login", "destination": "/admin/login.html" },
    { "source": "/api/admin/access-logs", "destination": "/api/admin/access-control" }
  ]
}
