{
  "github": {
    "silent": false,
    "autoJobCancelation": true
  },
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/truong/([^/]+)$", "destination": "/truong/$1/index.html" },
    { "source": "/(admin/[^/]+\\.html)$", "destination": "/$1" },
    { "source": "/admin/login", "destination": "/admin/login.html" },
    { "source": "/api/analytics", "destination": "/api/deepseek?action=analytics" },
    { "source": "/api/admin/analytics", "destination": "/api/deepseek?action=analytics" },
    { "source": "/api/admin/:path*", "destination": "/api/admin-handler?route=:path*" },
    { "source": "/tu-lam-ho-so", "destination": "/tu-lam-ho-so.html" }
  ]
}
