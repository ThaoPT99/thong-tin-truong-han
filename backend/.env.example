# Backend Admin CMS - Biến môi trường
# Copy file này thành .env và điền giá trị

# Secret key cho Flask session (bắt buộc - thay bằng chuỗi ngẫu nhiên)
SECRET_KEY=thay-bang-chuoi-ngau-nhien-dai-it-nhat-32-ky-tu

# Secret key cho JWT token (bắt buộc)
JWT_SECRET_KEY=thay-bang-chuoi-ngau-nhien-khac-voi-secret-key

# Port (mặc định 5000, Railway tự động set PORT)
PORT=5000

# Database path (mặc định: sqlite:///admin.db)
# DATABASE_URL=sqlite:///data/admin.db
